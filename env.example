# ABOOD القناص V3.0 - Environment Variables

# ============================================================
# مطلوب (REQUIRED)
# ============================================================
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN_HERE"
TELEGRAM_CHAT_ID="YOUR_CHAT_ID_HERE"

# ============================================================
# Webhook Secret (must match Pine Script setting)
# ============================================================
WEBHOOK_SECRET="abood_v3_secret"

# ============================================================
# Trading Hours (UTC) - 3:00 AM to 11:00 PM Riyadh
# ============================================================
ENABLE_TRADING_HOURS="true"
TRADING_START_HOUR="0"
TRADING_END_HOUR="20"
ENABLE_TRADING_DAYS="true"

# ============================================================
# Internal Scanner (backup when no TradingView webhook)
# ============================================================
ENABLE_INTERNAL_SCANNER="true"

# ============================================================
# Auto Reports
# ============================================================
ENABLE_DAILY_REPORT="true"
ENABLE_WEEKLY_REPORT="true"

# ============================================================
# Server (Render sets PORT automatically)
# ============================================================
PORT="8000"
HOST="0.0.0.0"
# RENDER_EXTERNAL_URL is set automatically by Render
